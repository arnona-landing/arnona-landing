<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>תשלום ארנונה</title>
<style>
 body {font-family: Heebo, Arial; background:#f6f8fb; margin:0; padding:0;}
 .wrap{max-width:900px;margin:auto;}
 .header{background:#1f487c;color:white;padding:16px;display:flex;gap:14px;align-items:center;}
 .header img{width:80px;height:auto;object-fit:contain;}
 .gold{height:5px;background:#d1a000;}
 .note{background:#f1f5ff;border:1px solid #dde8ff;padding:12px;margin:16px 0;border-radius:10px;}
 .card{background:white;padding:18px;border-radius:14px;box-shadow:0 8px 28px rgba(0,0,0,0.1);}
 .field{background:#f7f9fe;border:1px solid #e2e8f7;padding:12px;border-radius:12px;margin-bottom:12px;}
 .label{font-size:.85rem;color:#555;}
 .value{font-weight:700;margin-top:4px;}
 .cta a{display:inline-block;padding:12px 20px;border-radius:12px;margin:4px 0;font-weight:800;text-decoration:none;}
 .primary{background:#2c5fa7;color:white;}
 .secondary{background:white;border:1px solid #cfe0f6;color:#2c5fa7;}
 .footer{background:#0f2748;color:#fff;text-align:center;padding:20px;margin-top:20px;}
</style>
</head>
<body>
<div class="wrap">
 <div class="header">
   <img src="https://raw.githubusercontent.com/arnona-landing/arnona-landing/refs/heads/main/%D7%9E%D7%93%D7%99%D7%94.jfif" />
   <div>
     <b>מחלקת אכיפה — עיריית ירושלים</b><br>
     <small>תשלום ארנונה</small>
   </div>
 </div>
 <div class="gold"></div>
 <div class="card">
   <div class="note">תזכורת לפני נקיטת הליכי אכיפה.</div>
   <div class="field"><div class="label">שם תושב</div><div class="value" id="name"></div></div>
   <div class="field"><div class="label">מס' חשבון ארנונה</div><div class="value" id="account"></div></div>
   <div class="field"><div class="label">כתובת</div><div class="value" id="address"></div></div>
   <div class="field"><div class="label">גובה החוב (₪)</div><div class="value" id="balance" style="color:#b71c1c;"></div></div>
   <div class="cta">
     <a id="paybtn" class="primary" target="_blank">לתשלום</a><br>
     <a class="secondary" href="https://jeronlineforms.jerusalem.muni.il/ArnonaBalanceApproval" target="_blank">פירוט חשבון</a><br>
     <a class="secondary" href="tel:02-6293333">☎ מעבר לנציג</a><br>
     <a id="wa" class="secondary" target="_blank">🤖 ArnonaBot</a>
   </div>
 </div>
 <div class="footer">
   אגף ארנונה – עיריית ירושלים<br>שעות מענה: 08:00–18:00<br>טלפון המוקד: 02‑6293333
 </div>
</div>
<script>
const url = new URL(window.location.href);
function val(x){ return url.searchParams.get(x) || ""; }
document.getElementById("name").textContent = val("name");
document.getElementById("account").textContent = val("account");
document.getElementById("address").textContent = val("address");
document.getElementById("balance").textContent = val("balance");
document.getElementById("paybtn").href = val("pay");
document.getElementById("wa").href = "https://wa.me/972559597593?text=שלום " + encodeURIComponent(val("name"));
</script>
</body>
</html>
